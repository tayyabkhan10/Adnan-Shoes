{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "server",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "noEmitOnError": false,
    "types": ["node"]
  },
  "include": ["server"],
  "exclude": ["node_modules", "src", "dist"]
}